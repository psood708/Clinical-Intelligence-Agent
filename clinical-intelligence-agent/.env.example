# ─────────────────────────────────────────────
# Clinical Intelligence Agent — Environment Config
# Copy this to .env and fill in your values
# ─────────────────────────────────────────────

# ── LOCAL INFERENCE ──────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EXTRACTOR_MODEL=qwen3.5:9b           # Structured extraction (6.6 GB)
OLLAMA_VERIFIER_MODEL=gemma4:e2b            # Verification & reasoning (7.2 GB)
OLLAMA_SYNTHESIZER_MODEL=gemma4:e2b         # Local synthesis fallback (7.2 GB)
OLLAMA_EMBEDDING_MODEL=nomic-embed-text:v1.5  # Local embeddings

# ── FREE HOSTED APIS ─────────────────────────
# Groq — free tier: ~500K tokens/day, 315 tok/s on Llama 3.3 70B
# Sign up: https://console.groq.com
GROQ_API_KEY=gsk_...
GROQ_SYNTHESIZER_MODEL=llama-3.3-70b-versatile

# Cohere — free tier: 1K req/mo, Rerank 3.5 + Embed 4 (full RAG pipeline)
# Sign up: https://dashboard.cohere.com
COHERE_API_KEY=...
COHERE_RERANK_MODEL=rerank-english-v3.0
COHERE_EMBED_MODEL=embed-english-v3.0

# Google AI Studio — free tier: 1M token context, 10-15 RPM on Gemini 2.5 Flash
# Sign up: https://aistudio.google.com
GOOGLE_API_KEY=AIza...
GEMINI_MODEL=gemini-2.5-flash

# OpenRouter — free tier: ~30 models including DeepSeek R1, Qwen3
# Sign up: https://openrouter.ai
OPENROUTER_API_KEY=sk-or-...

# ── RETRIEVAL ────────────────────────────────
HNSW_INDEX_PATH=data/indexes/clinical_hnsw.bin
HNSW_M=16                    # HNSW construction param
HNSW_EF_CONSTRUCTION=200     # Build-time search depth
HNSW_EF_SEARCH=100           # Query-time search depth
TOP_K_RETRIEVAL=20           # Initial retrieval candidates
TOP_K_RERANK=5               # After reranking

# ── BIOBERT EMBEDDINGS ───────────────────────
BIOBERT_MODEL=dmis-lab/biobert-v1.1
BIOBERT_DEVICE=mps            # mps for M-series Mac, cuda for GPU, cpu for CPU
EMBEDDING_BATCH_SIZE=32
EMBEDDING_DIMENSION=768

# ── OBSERVABILITY ────────────────────────────
# Langfuse — self-hosted (see docker-compose.yml) or free cloud
# Sign up: https://cloud.langfuse.com
LANGFUSE_HOST=http://localhost:3000
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...

# ── EVALUATION ───────────────────────────────
EVAL_JUDGE_MODEL=ollama/gemma4:e2b      # LLM-as-judge for Ragas
EVAL_DATASET_PATH=data/eval/gold_standard.json
EVAL_BATCH_SIZE=10

# ── APPLICATION ──────────────────────────────
LOG_LEVEL=INFO
ENVIRONMENT=development         # development | production
MAX_DOCUMENT_SIZE_MB=10
SUPPORTED_FORMATS=pdf,txt,docx

# ── ROUTING STRATEGY ─────────────────────────
# privacy_first: Ollama only — no data leaves your machine
# speed_first:   Prefer Groq for synthesis, local for extraction
# hybrid:        Smart routing based on task type (default)
ROUTING_STRATEGY=hybrid
